# Firebase web config for production builds (used by CI deploy and any local
# `npm run build`). These values are PUBLIC by design — a Firebase web API key
# identifies the project; it is not a secret. Security is enforced by database
# rules + Cloud Functions, not by hiding these. See CLAUDE.md §4 and DEPLOY.md.
# Local dev still uses the gitignored .env.local.
#
# NOTE: Vite gives this file priority over .env.local for production builds, so
# it decides what every deployed bundle talks to. It must stay on twoagreeapp —
# the old aligned-9f843 project is DEAD.
VITE_FIREBASE_API_KEY=AIzaSyCIlrno2sY3TbFtrF0AC5lEH8bUyfOV8t8
# Auth handler domain. Set to the custom Hosting domain so Google's sign-in
# screen reads "twoagree.app" instead of "twoagreeapp.firebaseapp.com".
# Requires twoagree.app to be listed under Firebase console → Authentication →
# Settings → Authorized domains (it is — the app already serves auth there).
VITE_FIREBASE_AUTH_DOMAIN=twoagree.app
VITE_FIREBASE_DATABASE_URL=https://twoagreeapp-default-rtdb.europe-west1.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=twoagreeapp
VITE_FIREBASE_STORAGE_BUCKET=twoagreeapp.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=220230233383
VITE_FIREBASE_APP_ID=1:220230233383:web:b1b33c05f15d43c8380d02

# The Path is live. Set to false to hide the tab again.
VITE_PATH_ENABLED=true
