{
  "name": "twoagree-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:questions": "node scripts/build-questions.mjs",
    "prebuild": "node scripts/build-questions.mjs --check",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "pretest": "node scripts/build-questions.mjs --check",
    "test": "vitest run",
    "test:rules": "firebase emulators:exec --only database \"vitest run --config vitest.rules.config.ts\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/hanken-grotesk": "^5.2.8",
    "firebase": "^12.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.9"
  }
}
