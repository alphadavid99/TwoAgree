# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Env — local overrides are never committed; .env.example is the template.
# .env.production IS committed on purpose: it holds the public Firebase web
# config that CI needs to build a deployable bundle (see the notes in it).
.env
.env.local
.env.*.local

# Claude Code — local machine settings (launch.json is committed, this isn't)
.claude/settings.local.json

# Capacitor / iOS native shell — commit the ios/App source, ignore build
# artefacts and generated copies. Capacitor 8 uses Swift Package Manager, so
# there are no CocoaPods here. The ios/.gitignore the CLI generated covers most
# of this; these root entries make the intent explicit from the repo root.
ios/App/App/public/
ios/App/build/
ios/DerivedData/
*.xcuserstate
xcuserdata/
# Regenerated on every `cap copy` from capacitor.config.ts — never hand-edit.
ios/App/App/capacitor.config.json
ios/App/App/config.xml

# Firebase
.firebase/
firebase-debug.log
firebase-debug.*.log
database-debug.log
ui-debug.log
functions/lib/
.dataconnect/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Claude Code worktrees (local isolation, never shared)
.claude/worktrees/
