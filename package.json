{
  "name": "twoagree-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:questions": "node scripts/build-questions.mjs",
    "build:path": "node scripts/build-path.mjs",
    "prebuild": "node scripts/build-questions.mjs --check && node scripts/build-path.mjs --check",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "pretest": "node scripts/build-questions.mjs --check && node scripts/build-path.mjs --check",
    "test": "vitest run",
    "test:rules": "firebase emulators:exec --only database \"vitest run --config vitest.rules.config.ts\"",
    "preview": "vite preview",
    "cap:sync": "npm run build && cap sync ios",
    "cap:copy": "npm run build && cap copy ios",
    "cap:open": "cap open ios",
    "ios:assets": "npx @capacitor/assets generate --ios --iconBackgroundColor '#3E1A2E' --splashBackgroundColor '#3E1A2E' --splashBackgroundColorDark '#3E1A2E'"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^8.3.0",
    "@capacitor/app": "^8.1.1",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@capacitor/splash-screen": "^8.0.2",
    "@capacitor/status-bar": "^8.0.3",
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/hanken-grotesk": "^5.2.8",
    "firebase": "^12.15.0",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.9"
  }
}
